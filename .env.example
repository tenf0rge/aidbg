# aidbg / opencode engine — environment for the optional LiteLLM provider.
# Copy to `.env` (gitignored) and `export`, or set in your shell. The bundled free
# opencode model works WITHOUT any of these; these are only needed when you point
# aidbg at a litellm/* model through the LiteLLM (OpenAI-compatible) proxy.

# Base URL of your LiteLLM proxy (OpenAI-compatible endpoint)
LITELLM_BASE_URL=http://localhost:4000

# API key your LiteLLM proxy expects
LITELLM_API_KEY=sk-replace-me
